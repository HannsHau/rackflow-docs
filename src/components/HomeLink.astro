---
// No server-side env var access needed
---

<a href="#" class="home-link" id="rackflow-home-link">
  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" class="home-icon">
    <path d="M240-200h120v-240h240v240h120v-360L480-740 240-560v360Zm-80 80v-480l320-240 320 240v480H520v-240h-80v240H160Zm320-350Z"/>
  </svg>
  Go to RackFlow
</a>

<script>
  // Set the home link URL from runtime environment
  document.addEventListener('DOMContentLoaded', () => {
    const homeLink = document.getElementById('rackflow-home-link');
    if (homeLink && window.ENV?.PUBLIC_HOME_URL) {
      homeLink.setAttribute('href', window.ENV.PUBLIC_HOME_URL);
    }
  });
</script>