---
import {
	HOME_URL,
	BLOG_URL,
	DOCS_URL,
	demoUrl,
	loginUrl,
	signupUrl,
} from '../lib/urls';
import logo from '../assets/logo.svg';
---

<div class="rackflow-site-header">
	<div class="rackflow-header-content">
		<a href={HOME_URL} class="logo" aria-label="RackFlow home" data-rf-link="home">
			<img src={logo.src} alt="" class="logo-image" width="42" height="42" />
			<span class="logo-text">RackFlow</span>
		</a>
		<input type="checkbox" id="rackflow-nav-toggle" class="nav-toggle" aria-hidden="true" />
		<label for="rackflow-nav-toggle" class="nav-toggle-button" aria-label="Toggle navigation menu">
			<span></span>
			<span></span>
			<span></span>
		</label>
		<div class="header-right">
			<nav class="nav" aria-label="Site">
				<a href={`${HOME_URL}/#product-section`} class="nav-link" data-rf-link="home-product">Product</a>
				<a href={BLOG_URL} class="nav-link" data-rf-link="blog">Blog</a>
				<a href={DOCS_URL} class="nav-link" aria-current="page" data-rf-link="docs">Docs</a>
				<a href={`${HOME_URL}/pricing`} class="nav-link" data-rf-link="home-pricing">Pricing</a>
				<a href={demoUrl()} class="nav-link">Request&nbsp;Demo</a>
			</nav>
			<div class="header-actions">
				<a href={loginUrl()} class="btn btn-ghost" data-rf-link="app-login">Log In</a>
				<a href={signupUrl()} class="btn btn-primary" data-rf-link="app-signup">Start Free</a>
			</div>
		</div>
	</div>
</div>

<style>
	@layer starlight.core {
		.rackflow-site-header {
			width: 100%;
		}

		.rackflow-header-content {
			display: flex;
			justify-content: space-between;
			align-items: center;
			max-width: 1200px;
			margin: 0 auto;
			padding: 0 1.5rem;
			width: 100%;
		}
	}
</style>
