---
// Lightweight consent banner shared across rackflow.app subdomains via cookie
---
<style>
  .consent-banner{position:fixed;bottom:0;left:0;right:0;z-index:9999;display:none;background:#0f172a;color:#e2e8f0;padding:12px 16px;border-top:1px solid #1f2937}
  .consent-banner__content{max-width:960px;margin:0 auto;display:flex;gap:12px;align-items:center;justify-content:space-between}
  .consent-banner__text{font-size:14px;line-height:1.4;margin:0;flex:1}
  .consent-banner__actions{display:flex;gap:8px}
  .consent-banner__btn{appearance:none;border:1px solid #334155;background:#1f2937;color:#e2e8f0;border-radius:6px;padding:8px 12px;font-size:14px;cursor:pointer}
  .consent-banner__btn--primary{background:#2563eb;border-color:#1d4ed8}
</style>

<div id="consent-banner" class="consent-banner" role="dialog" aria-live="polite" aria-label="Cookie consent">
  <div class="consent-banner__content">
    <p class="consent-banner__text">
      We use cookies for analytics to improve Rackflow. You can accept or reject. Read our privacy policy for details.
    </p>
    <div class="consent-banner__actions">
      <button id="consent-reject" class="consent-banner__btn" type="button">Reject</button>
      <button id="consent-accept" class="consent-banner__btn consent-banner__btn--primary" type="button">Accept</button>
    </div>
  </div>
  <script is:inline>
    (function(){
      var CONSENT_KEY='marketing_consent_v1';
      function getCookie(name){
        var value='; '+document.cookie;var parts=value.split('; '+name+'=');if(parts.length===2) return parts.pop().split(';').shift();
      }
      function setCookie(name,value,days){
        var expires=''; if(days){ var date=new Date(); date.setTime(date.getTime()+days*24*60*60*1000); expires='; expires='+date.toUTCString(); }
        var hostname=window.location&&window.location.hostname?window.location.hostname:'';
        var isRackflow=/(^|\.)rackflow\.app$/.test(hostname);
        var domainAttr=isRackflow?'; domain=.rackflow.app':'';
        document.cookie=name+'='+value+expires+'; path=/'+domainAttr+'; SameSite=Lax';
      }
      function shouldShow(){
        var v=getCookie(CONSENT_KEY); return !(v==='accepted'||v==='rejected');
      }
      var banner=document.getElementById('consent-banner');
      var acceptBtn=document.getElementById('consent-accept');
      var rejectBtn=document.getElementById('consent-reject');
      if(shouldShow() && banner){ banner.style.display='block'; }
      function accept(){ setCookie(CONSENT_KEY,'accepted',365*2); banner&&(banner.style.display='none'); try{ localStorage.setItem(CONSENT_KEY,'accepted'); }catch(e){} }
      function reject(){ setCookie(CONSENT_KEY,'rejected',365*2); banner&&(banner.style.display='none'); try{ localStorage.setItem(CONSENT_KEY,'rejected'); }catch(e){} }
      acceptBtn&&acceptBtn.addEventListener('click',accept);
      rejectBtn&&rejectBtn.addEventListener('click',reject);
    })();
  </script>
</div>


